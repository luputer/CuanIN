generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Post {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Profile {
  id        Int      @id @default(autoincrement())
  bio       String?
  userId    Int      @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id               String      @id @default(uuid())
  name             String
  shortDescription String?     @db.Text
  description      String?     @db.Text
  price            Decimal
  type             ProductType @default(WEBINAR)
  startDate        DateTime?
  endDate          DateTime?
  link             String?
  status           String      @default("published")
  userId           String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  image            String?
  slug             String?     @unique @default(cuid())
  benefit          Json?
  formFields       FormField[]
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchases        Purchase[]
}

model FormField {
  id        String       @id @default(uuid())
  productId String
  label     String
  type      FieldType    @default(SHORT)
  options   Json?
  required  Boolean      @default(false)
  order     Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  answers   FormAnswer[]
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Purchase {
  id         String       @id @default(uuid())
  productId  String
  buyerName  String
  buyerEmail String
  buyerPhone String
  amount     Decimal      @default(0)
  status     String       @default("completed")
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  answers    FormAnswer[]
  product    Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model FormAnswer {
  id          String    @id @default(uuid())
  purchaseId  String
  formFieldId String
  answer      String
  createdAt   DateTime  @default(now())
  formField   FormField @relation(fields: [formFieldId], references: [id], onDelete: Cascade)
  purchase    Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([purchaseId])
  @@index([formFieldId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified_at")
  image         String?
  password      String?
  status        String    @default("active")
  statusPayment String    @default("free")
  googleId      String?   @map("google_id")
  phoneNumber   String?   @map("phone_number")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  catalog       Catalog?
  products      Product[]
  role          RoleType  @default(CREATOR)
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Catalog {
  id        String   @id @default(uuid())
  slug      String   @unique
  bio       String?
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ProductType {
  WEBINAR
  DIGITAL_PRODUCT
  KELAS_ONLINE
}

enum RoleType {
  CREATOR
  ADMIN
  USER
}

enum FieldType {
  SHORT
  LONG
  MULTIPLE_CHOICE
  CHECKBOX
  DROPDOWN
}
