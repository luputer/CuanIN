generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma_v2"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Post {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Profile {
  id        Int      @id @default(autoincrement())
  bio       String?
  banner    String?
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id               String        @id @default(uuid())
  name             String
  shortDescription String?       @db.Text
  description      String?       @db.Text
  price            Decimal
  type             ProductType   @default(WEBINAR)
  startDate        DateTime?
  endDate          DateTime?
  link             String?
  status           String        @default("published")
  userId           String
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  image            String?
  images           Json?
  enableVoucher    Boolean       @default(false)
  vouchers         Json?
  enableNotes      Boolean       @default(false)
  slug             String?       @unique @default(cuid())
  benefit          Json?
  dateDeadline     DateTime?
  platform         String?
  quota            Int?
  format           String?
  duration         String?
  notes            String?       @db.Text
  formFields       FormField[]
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  views            ProductView[]
  purchases        Purchase[]
}

model ProductView {
  id        String   @id @default(uuid())
  productId String
  createdAt DateTime @default(now())
  visitorId String?
  browser   String?
  device    String?
  ipHash    String?
  os        String?
  userAgent String?
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([visitorId])
  @@index([ipHash])
  @@index([browser])
  @@index([device])
  @@index([productId, visitorId])
  @@index([createdAt])
}

model FormField {
  id        String       @id @default(uuid())
  productId String
  label     String
  type      FieldType    @default(SHORT)
  options   Json?
  required  Boolean      @default(false)
  order     Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  answers   FormAnswer[]
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Purchase {
  id                  String       @id @default(uuid())
  productId           String
  buyerName           String
  buyerEmail          String
  buyerPhone          String
  amount              Decimal      @default(0)
  status              String       @default("pending")
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  xenditInvoiceId     String?
  xenditInvoiceUrl    String?
  paidAt              DateTime?
  xenditPaymentMethod String?
  answers             FormAnswer[]
  product             Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([xenditInvoiceId])
}

model FormAnswer {
  id          String    @id @default(uuid())
  purchaseId  String
  formFieldId String
  answer      String
  createdAt   DateTime  @default(now())
  formField   FormField @relation(fields: [formFieldId], references: [id], onDelete: Cascade)
  purchase    Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([purchaseId])
  @@index([formFieldId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id             String         @id @default(cuid())
  name           String?
  email          String?        @unique
  emailVerified  DateTime?      @map("email_verified_at")
  image          String?
  password       String?
  status         String         @default("active")
  statusPayment  String         @default("free")
  googleId       String?        @map("google_id")
  phoneNumber    String?        @map("phone_number")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  role           RoleType       @default(USER)
  accounts       Account[]
  catalog        Catalog?
  catalogViews   CatalogView[]
  products       Product[]
  profile        Profile?
  sessions       Session[]
  withdrawals    Withdrawal[]
  balanceEntries BalanceEntry[]
  vouchers       Voucher[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Catalog {
  id        String        @id @default(uuid())
  slug      String        @unique
  userId    String        @unique
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  views     CatalogView[]
}

model CatalogView {
  id        String   @id @default(uuid())
  catalogId String
  userId    String
  visitorId String?
  ipHash    String?
  userAgent String?
  browser   String?
  os        String?
  device    String?
  createdAt DateTime @default(now())
  catalog   Catalog  @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([catalogId])
  @@index([userId])
  @@index([visitorId])
  @@index([ipHash])
  @@index([browser])
  @@index([device])
  @@index([userId, visitorId])
  @@index([createdAt])
}

model Withdrawal {
  id                String           @id @default(uuid())
  userId            String
  amount            Decimal
  bankCode          String
  bankName          String
  accountNumber     String
  accountHolderName String
  email             String
  status            WithdrawalStatus @default(PENDING)
  referenceId       String           @unique
  xenditPayoutId    String?
  failureCode       String?
  failureMessage    String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([xenditPayoutId])
}

model BalanceEntry {
  id        String           @id @default(uuid())
  userId    String
  amount    Decimal
  type      BalanceEntryType
  refId     String?
  note      String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refId])
  @@index([userId, createdAt])
}

enum ProductType {
  WEBINAR
  DIGITAL_PRODUCT
  KELAS_ONLINE
}

enum RoleType {
  CREATOR
  ADMIN
  USER
}

enum FieldType {
  SHORT
  LONG
  MULTIPLE_CHOICE
  CHECKBOX
  DROPDOWN
}

enum WithdrawalStatus {
  PENDING
  ACCEPTED
  REQUESTED
  SUCCEEDED
  FAILED
  CANCELLED
  REVERSED
}

enum BalanceEntryType {
  PURCHASE_COMPLETED
  WITHDRAWAL_REQUESTED
  WITHDRAWAL_FAILED
  WITHDRAWAL_REVERSED
}

enum VoucherType {
  PERSEN
  NOMINAL
}

model Voucher {
  id         String      @id @default(uuid())
  code       String      @unique
  name       String?
  type       VoucherType @default(PERSEN)
  discount   Decimal
  startDate  DateTime
  endDate    DateTime
  status     String      @default("aktif") // aktif, nonaktif, expired
  usageType  String      @default("ALL_PRODUCTS") // ALL_PRODUCTS, SELECTED_PRODUCTS, SINGLE_CHECKOUT
  usageLimit Int?
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([userId])
}
