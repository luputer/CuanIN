// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider  = "postgresql"
    url       = env("DATABASE_URL")
    directUrl = env("DIRECT_URL")
}

model role {
    id_role      Int    @id @default(autoincrement())
    nama_role    String @db.VarChar(40)
    guarded_name String @db.VarChar(40)
    users        user[]
}

model user {
    id_user           Int       @id @default(autoincrement())
    id_role           Int
    nama_user         String    @db.VarChar(40)
    email             String    @db.VarChar(40)
    password          String    @db.VarChar(40)
    phone             String    @db.VarChar(14)
    id_google         String?   @db.VarChar(30)
    photo_url         String?   @db.VarChar(40)
    email_verified_at DateTime?
    created_at        DateTime  @default(now())
    updated_at        DateTime  @updatedAt
    remember_token    String?   @db.VarChar(100)
    status_user       String    @db.VarChar(40)

    role         role           @relation(fields: [id_role], references: [id_role])
    saldos       saldo[]
    produks      produk[]
    transaksis   transaksi[]
    catalogs     catalog[]
    penarikans   penarikan[]
    visitor_logs visitor_logs[]
    form_answers form_answer[]
}

model saldo {
    id_saldo Int     @id @default(autoincrement())
    id_user  Int
    saldo    Decimal
    rekening String  @db.VarChar(40)
    user     user    @relation(fields: [id_user], references: [id_user])
}

model produk {
    id_produk     Int     @id @default(autoincrement())
    id_kategori   Int
    id_user       Int
    nama_produk   String  @db.VarChar(40)
    deskripsi     String? @db.Text
    thumbnail_url String? @db.VarChar(100)
    tipe          String  @db.VarChar(40)
    status        String  @db.VarChar(40)
    catatan       String? @db.Text

    user            user             @relation(fields: [id_user], references: [id_user])
    kategori        kategori         @relation(fields: [id_kategori], references: [id_kategori])
    webinar         webinar?
    produk_digital  produk_digital?
    transaksis      transaksi[]
    detail_catalogs detail_catalog[]
    form_fields     form_field[]
}

model kategori {
    id_kategori   Int      @id @default(autoincrement())
    nama_kategori String   @db.VarChar(40)
    produks       produk[]
}

model webinar {
    id_produk    Int      @id
    tanggal      DateTime
    jam_mulai    DateTime @db.Time
    jam_selesai  DateTime @db.Time
    kuota        Decimal
    batas_daftar DateTime
    webinar_url  String   @db.VarChar(40)
    produk       produk   @relation(fields: [id_produk], references: [id_produk])
}

model produk_digital {
    id_produk          Int    @id
    produk_digital_url String @db.VarChar(40)
    produk             produk @relation(fields: [id_produk], references: [id_produk])
}

model kelas {
    id_produk Int      @id
    durasi    DateTime @db.Time
    kelas_url String   @db.VarChar(40)
}

model transaksi {
    id_transaksi     Int       @id @default(autoincrement())
    id_metode        Int
    id_produk        Int
    id_user          Int
    jumlah_transaksi Decimal
    status_transaksi String    @db.VarChar(40)
    snap_token       String?   @db.VarChar(40)
    id_payment       Int?
    payment_type     String?   @db.VarChar(40)
    payment_time     DateTime?
    payment_detail   String?   @db.Text

    user         user         @relation(fields: [id_user], references: [id_user])
    produk       produk       @relation(fields: [id_produk], references: [id_produk])
    metode_bayar metode_bayar @relation(fields: [id_metode], references: [id_metode])
}

model metode_bayar {
    id_metode   Int         @id @default(autoincrement())
    nama_metode String      @db.VarChar(40)
    transaksis  transaksi[]
}

model penarikan {
    id_penarikan     Int     @id @default(autoincrement())
    id_user          Int
    jumlah_penarikan Decimal
    nama_bank        String  @db.VarChar(40)
    nomor_akun       Decimal
    status_penarikan String  @db.VarChar(40)

    user user @relation(fields: [id_user], references: [id_user])
}

model catalog {
    id_catalog   Int    @id @default(autoincrement())
    id_user      Int
    link_catalog String @db.VarChar(40)

    user            user             @relation(fields: [id_user], references: [id_user])
    detail_catalogs detail_catalog[]
}

model detail_catalog {
    id_detail_catalog   Int    @id @default(autoincrement())
    id_catalog          Int
    id_produk           Int
    link_detail_catalog String @db.VarChar(40)

    catalog catalog @relation(fields: [id_catalog], references: [id_catalog])
    produk  produk  @relation(fields: [id_produk], references: [id_produk])
}

model form_field {
    id_form_field Int     @id @default(autoincrement())
    id_produk     Int
    field_judul   String  @db.VarChar(100)
    field_type    String  @db.VarChar(100)
    field_option  String  @db.VarChar(100)
    is_required   Int // Menggunakan Int sesuai diagram, bisa diubah ke Boolean
    urutan        Decimal

    produk produk @relation(fields: [id_produk], references: [id_produk])
}

model form_answer {
    id_answer     Int    @id @default(autoincrement())
    id_user       Int
    id_form_field Int
    jawaban       String @db.Text

    user user @relation(fields: [id_user], references: [id_user])
}

model visitor_logs {
    id_visitor Int      @id @default(autoincrement())
    id_user    Int
    ip_address String   @db.VarChar(40)
    visited_at DateTime @default(now())

    user user @relation(fields: [id_user], references: [id_user])
}
